# Macau Casino Marketing Assistant - Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# A2A AGENT ENDPOINTS
# =============================================================================

# Local development: use localhost; OpenShift: uses in-cluster service URL via configmap
CODER_A2A_URL=http://localhost:8001
CUSTOMER_A2A_URL=http://localhost:8002
MARKETING_A2A_URL=http://localhost:8003
K8S_A2A_URL=http://localhost:8004

# =============================================================================
# EMAIL (Optional - simulated by default)
# =============================================================================

EMAIL_MODE=simulate
# RESEND_API_KEY=re_xxxxx

# =============================================================================
# APPLICATION
# =============================================================================

SERVICE_PORT=8501
DEBUG=true
LOG_LEVEL=INFO
SUPPORTED_LANGUAGES=en,zh-CN
DEFAULT_LANGUAGE=en
